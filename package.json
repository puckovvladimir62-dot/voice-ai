{
  "name": "voice-ai",
  "version": "1.1.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "node build-dist.js",
    "release": "node build-dist.js --publish"
  },
  "build": {
    "appId": "com.voiceai.app",
    "productName": "Voice AI",
    "afterPack": "./afterPack.js",
    "files": [
      "**/*",
      "!test-tts.js",
      "!rcedit.exe",
      "!afterPack.js",
      "!build-dist.js",
      "!*.orig"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Voice AI"
    },
    "publish": {
      "provider": "github",
      "owner": "puckovvladimir62-dot",
      "repo": "voice-ai",
      "private": true
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^5.4.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "electron-updater": "^6.8.3",
    "marked": "^4.3.0",
    "msedge-tts": "^2.0.5"
  }
}
